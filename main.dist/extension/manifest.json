{
  "manifest_version": 3,
  "name": "VEO Pro Max Bridge",
  "version": "2.3.0",
  "description": "Bridges VEO web tokens and headers to VEO Pro Max app via WebSocket",
  "permissions": [
    "webRequest",
    "cookies",
    "activeTab",
    "tabs",
    "scripting",
    "storage",
    "alarms",
    "offscreen"
  ],
  "host_permissions": [
    "*://labs.google/*",
    "*://*.googleapis.com/*",
    "*://*.aisandbox.com/*",
    "*://aistudio.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://labs.google/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}